# Copy values from ai-module-writer/.env
TAKARO_HOST=https://api.next.takaro.dev
TAKARO_USERNAME=your@email.com
TAKARO_PASSWORD=yourpassword
TAKARO_DOMAIN_ID=your-domain-name

# Path to the local modules directory (default shown below)
MODULES_ROOT=D:/BachMCP/ai-module-writer/modules

# Path to the MCP HTTP server (default: 3000, matches takaro-minecraft/.mcp.json)
PORT=3000

# Port for the Mineflayer bot service (default: 3101, from ai-module-writer docker-compose)
BOT_PORT=3101

# Langfuse tracing (optional — server starts without these, tracing is silently disabled)
# Get keys at https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_DEBUG=true

# Eval runner settings (src/scripts/eval-runner.ts)
# Max turns Claude Code is allowed per module run
EVAL_MAX_TURNS=40
# Comma-separated models to benchmark (default: all three)
EVAL_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5-20251001