# Copy values from ai-module-writer/.env
TAKARO_HOST=https://api.next.takaro.dev
TAKARO_USERNAME=your@email.com
TAKARO_PASSWORD=yourpassword
TAKARO_DOMAIN_ID=your-domain-name

# Path to the local modules directory (default shown below)
MODULES_ROOT=D:/BachMCP/ai-module-writer/modules

# Path to the MCP HTTP server (default: 3000, matches takaro-minecraft/.mcp.json)
PORT=3000

# Port for the Mineflayer bot service (default: 3101, from ai-module-writer docker-compose)
BOT_PORT=3101
